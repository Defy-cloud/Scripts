--   Tab:AddSection(name)           → Section
--   Section:AddToggle(cfg)         → { Set, Get }
--   Section:AddSlider(cfg)         → { Set, Get }
--   Section:AddButton(cfg)         → nil
--   Section:AddDropdown(cfg)       → { Set, Get }
--   Section:AddInput(cfg)          → { Set, Get }
--   Section:AddLabel(cfg)          → { Set, Get }
--   Section:AddKeybind(cfg)        → { Get }
--   Section:AddColorPicker(cfg)    → { Set, Get }
